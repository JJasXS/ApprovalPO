@page "/ScanPO"
@model ApprovalPO.Pages.ScanPOModel
@{
    ViewData["Title"] = "Scanning PO";
    ViewData["AppName"] = "Approval PO";
    var ordersJsonUrl = Url.Page("/ScanPO", null, new { handler = "OrdersJson" })!;
    var detailPageUrl = "/ScanPODetail";
    var userName = User.Identity?.Name ?? User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "User";
}

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="~/css/scan.css" asp-append-version="true" />

@{
    var receivedGoodsJsonUrl = Url.Page("/ScanPO", null, new { handler = "ReceivedGoodsJson" })!;
    var receivedDetailPageUrl = "/ScanReceivedDetail";
}
<div id="scanPageConfig" hidden
     data-orders-json-url="@ordersJsonUrl"
     data-received-goods-json-url="@receivedGoodsJsonUrl"
     data-detail-page-url="@detailPageUrl"
     data-received-detail-page-url="@receivedDetailPageUrl"></div>

<header class="scan-header">
    <div class="scan-header-inner">
        <div class="scan-header-titles">
            <a asp-page="/Dashboard" class="scan-back-link" title="Back to home" aria-label="Back to home">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="15 18 9 12 15 6"/>
                </svg>
            </a>
            <h1 class="scan-header-title">Scanning PO</h1>
        </div>
        <div class="scan-header-actions">
            <div class="scan-menu-wrap">
                <button class="scan-menu-btn" id="scanMenuBtn" type="button" aria-expanded="false" aria-controls="scanMenuPanel" aria-label="Open menu">
                    <span></span><span></span><span></span>
                </button>
                <div id="scanMenuPanel" class="scan-menu-panel" hidden>
                    <div class="scan-menu-user">@userName</div>
                    <a asp-page="/Dashboard" class="scan-menu-link">&#8592; Back to home</a>
                    <form method="post" asp-page="/Logout" style="margin:0;padding:0">
                        <button type="submit" class="scan-menu-link scan-menu-link--danger">Sign out</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</header>

<main class="scan-main">
    <div class="scan-main-inner">
        @if (TempData["ScanSubmitMessage"] is string submitMsg && !string.IsNullOrWhiteSpace(submitMsg))
        {
            <p class="scan-flash scan-flash--ok" role="status">@submitMsg</p>
        }

        <p id="scanHttpsBanner" class="scan-https-banner" hidden role="note">
            For live QR camera, use HTTPS:
            <a id="scanHttpsBannerLink" href="#">open Scan PO on HTTPS</a>
            (or take a photo of the QR on HTTP).
        </p>

        <div class="scan-search-bar">
            <input id="scanSearch" class="scan-search-input" type="search" placeholder="Search PO #…" autocomplete="off" />
            <span id="scanResultCount" class="scan-result-count"></span>
        </div>

        <p id="scanListHint" class="scan-list-hint">ERP-approved POs to scan — tap a row to open lines.</p>

        <div class="scan-table-wrap">
            <div class="scan-tabs-wrap scan-tabs-wrap--table">
                <div class="scan-tabs" role="tablist" aria-label="Scan PO status">
                    <button type="button" id="scanTabToScan" class="scan-tab-btn is-active" role="tab" aria-selected="true" data-scan-tab="toScan">
                        To scan (<span id="scanCountToScan">0</span>)
                    </button>
                    <button type="button" id="scanTabSubmitted" class="scan-tab-btn" role="tab" aria-selected="false" data-scan-tab="submitted">
                        Submitted (<span id="scanCountSubmitted">0</span>)
                    </button>
                    <button type="button" id="scanTabReceived" class="scan-tab-btn" role="tab" aria-selected="false" data-scan-tab="received">
                        Received goods (<span id="scanCountReceived">0</span>)
                    </button>
                </div>
            </div>
            <table class="scan-table scan-table--list">
                <thead>
                    <tr>
                        <th id="scanListCol1Header">PO #</th>
                        <th id="scanListDateHeader">Date</th>
                        <th class="num">Amount</th>
                    </tr>
                </thead>
                <tbody id="scanTableBody">
                    <tr id="scanLoadingRow" class="scan-loading-row">
                        <td colspan="3">Loading…</td>
                    </tr>
                </tbody>
            </table>
            <div id="scanEmpty" class="scan-empty" hidden>
                No purchase orders in this tab.
            </div>
        </div>
        <div class="scan-list-footer">
            <button type="button" id="scanLoadMoreBtn" class="scan-load-more-btn" hidden>More</button>
        </div>
    </div>
</main>

<script src="~/js/scan-po.js" asp-append-version="true"></script>
<script>
    (function () {
        if (window.isSecureContext) return;
        var banner = document.getElementById('scanHttpsBanner');
        var a = document.getElementById('scanHttpsBannerLink');
        if (!banner || !a) return;
        var host = location.hostname || 'localhost';
        var httpsMeta = document.querySelector('meta[name="approval-https-port"]');
        var httpsPort = (httpsMeta && httpsMeta.content) ? httpsMeta.content : '2096';
        var url = 'https://' + host + ':' + httpsPort + '/ScanPO';
        a.href = url;
        a.textContent = url;
        banner.hidden = false;
    })();
</script>
