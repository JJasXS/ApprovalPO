@page "/ScanPO"
@model ApprovalPO.Pages.ScanPOModel
@{
    ViewData["Title"] = "Scanning PO";
    ViewData["AppName"] = "Approval PO";
    var ordersJsonUrl = Url.Page("/ScanPO", null, new { handler = "OrdersJson" })!;
    var detailPageUrl = "/ScanPODetail";
    var userName = User.Identity?.Name ?? User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "User";
}

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="~/css/scan.css" asp-append-version="true" />

<div id="scanPageConfig" hidden
     data-orders-json-url="@ordersJsonUrl"
     data-detail-page-url="@detailPageUrl"></div>

<header class="scan-header">
    <div class="scan-header-inner">
        <div class="scan-header-titles">
            <h1 class="scan-header-title">Scanning PO</h1>
        </div>
        <div class="scan-header-actions">
            <div class="scan-menu-wrap">
                <button class="scan-menu-btn" id="scanMenuBtn" type="button" aria-expanded="false" aria-controls="scanMenuPanel" aria-label="Open menu">
                    <span></span><span></span><span></span>
                </button>
                <div id="scanMenuPanel" class="scan-menu-panel" hidden>
                    <div class="scan-menu-user">@userName</div>
                    <form method="post" asp-page="/Logout" style="margin:0;padding:0">
                        <button type="submit" class="scan-menu-link scan-menu-link--danger">Sign out</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</header>

<main class="scan-main">
    <div class="scan-main-inner">
        <div class="scan-search-bar">
            <input id="scanSearch" class="scan-search-input" type="search" placeholder="Search PO #…" autocomplete="off" />
            <span id="scanResultCount" class="scan-result-count"></span>
        </div>

        <div class="scan-list-hint">Approved purchase orders only — tap a row to open details.</div>

        <div class="scan-table-wrap">
            <table class="scan-table scan-table--list">
                <thead>
                    <tr>
                        <th>PO #</th>
                        <th>Date</th>
                        <th class="num">Amount</th>
                        <th class="scan-th-chev" aria-hidden="true"></th>
                    </tr>
                </thead>
                <tbody id="scanTableBody">
                    <tr id="scanLoadingRow" class="scan-loading-row">
                        <td colspan="4">Loading…</td>
                    </tr>
                </tbody>
            </table>
            <div id="scanEmpty" class="scan-empty" hidden>
                No approved purchase orders found.
            </div>
        </div>
        <div class="scan-list-footer">
            <button type="button" id="scanLoadMoreBtn" class="scan-load-more-btn" hidden>More</button>
        </div>
    </div>
</main>

<script src="~/js/scan-po.js" asp-append-version="true"></script>
