@page
@model ApprovalPO.Pages.PurchaseOrdersModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Purchase Orders";
    var ordersJsonUrl = Url.Page("/PurchaseOrders", null, new { handler = "OrdersJson" })!;
    var linesJsonUrlBase = Url.Page("/PurchaseOrders", null, new { handler = "LinesJson" })!;
    var setTransferableUrl = Url.Page("/PurchaseOrders", null, new { handler = "SetTransferable" })!;
    var setLineTransferableUrl = Url.Page("/PurchaseOrders", null, new { handler = "SetLineTransferable" })!;
    var pendingNotifySnapshotUrl = Url.Page("/PurchaseOrders", null, new { handler = "PendingNotifySnapshot" })!;
    var csrf = Antiforgery.GetAndStoreTokens(HttpContext).RequestToken;
}

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="~/css/po.css" asp-append-version="true" />

<div id="poPageConfig" hidden
     data-orders-json-url="@ordersJsonUrl"
     data-lines-json-url-base="@linesJsonUrlBase"
     data-set-transferable-url="@setTransferableUrl"
     data-set-line-transferable-url="@setLineTransferableUrl"
     data-pending-notify-url="@pendingNotifySnapshotUrl"
     data-pending-notify-poll-ms="@Model.PendingNotifyPollMilliseconds"
     data-web-push-public-key="@(Model.WebPushPublicKey ?? "")"
     data-web-push-subscribe-url="/api/web-push/subscribe"
     data-web-push-unsubscribe-url="/api/web-push/unsubscribe"
     data-csrf-token="@csrf"
     data-high-value-threshold="@Model.HighValueThreshold.ToString(System.Globalization.CultureInfo.InvariantCulture)"></div>

<main class="po-main">
    <header class="po-header po-header--hero">
        <div class="po-header__inner">
            <div class="po-header__titles">
                <h1 class="po-header__title">Purchase order approvals</h1>
            </div>
            <div class="po-header__actions">
                <div class="po-header__menu">
                    <button id="poHeadToggleBtn" class="menu-btn menu-btn--head-toggle" type="button" aria-expanded="true" aria-controls="poTableHeadPanel" aria-label="Hide filters and tabs" title="Show or hide filters and tabs">
                        <svg class="menu-btn__chev" width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M6 14l6-6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </button>
                </div>
                <div class="po-header__menu">
                    <button id="menuBtn" class="menu-btn" type="button" aria-expanded="false" aria-controls="menuPanel" aria-label="Open menu">
                        <span></span><span></span><span></span>
                    </button>
                    <div id="menuPanel" class="menu-panel" hidden>
                        <div class="menu-user">@User.Identity?.Name</div>
                        <button type="button" id="poNotifyMenuStop" class="menu-link menu-link--button" hidden>Stop order alerts</button>
                        @if (Model.ShowDevNotifyTools)
                        {
                            <button type="button" id="poDevNotifyPing" class="menu-link menu-link--button">Test browser notify</button>
                        }
                        <form method="post" asp-page="/Logout" class="menu-logout-form">
                            <button type="submit" class="menu-link menu-link--button">Sign out</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <div class="po-main__inner">
        <div id="poTableHeadPanel" class="po-table-wrap__head">
            <div class="po-toolbar">
                <div class="po-toolbar__cluster">
                    <label class="po-toolbar-select-all" title="Select every pending PO shown in the list (respects the Pending tab and filters)">
                        <input type="checkbox" id="bulkSelectAll" disabled aria-label="Select all visible pending purchase orders" />
                        <span class="po-toolbar-select-all__text">Select all</span>
                    </label>
                    <button type="button" id="bulkApproveBtn" class="po-btn po-btn--bulk" disabled>Bulk approve</button>
                    <button type="button" id="filterClearBtn" class="po-btn po-btn--filter-clear">Clear</button>
                </div>
            </div>

            <div class="po-filters" id="poFilters">
                <select id="filterVendor" class="po-filter-input" aria-label="Vendor">
                    <option value="">All vendors</option>
                    @foreach (var v in Model.DistinctVendors)
                    {
                        <option value="@v">@v</option>
                    }
                </select>
                <input id="filterDateFrom" class="po-filter-input" type="date" aria-label="From date" />
            </div>

            <div class="tabs-wrap">
                <div class="tabs" role="tablist" aria-label="PO status tabs">
                    <button id="tabPending" class="tab-btn is-active" type="button" role="tab" aria-selected="true">Pending (<span id="countPending">0</span>)</button>
                    <button id="tabApproved" class="tab-btn" type="button" role="tab" aria-selected="false">Approved (<span id="countApproved">0</span>)</button>
                    <button id="tabRejected" class="tab-btn" type="button" role="tab" aria-selected="false">Cancelled (<span id="countRejected">0</span>)</button>
                </div>
            </div>
        </div>
        <div class="po-table-wrap" id="poTableWrap">
        <div id="poEmptyState" class="po-empty" hidden role="status" aria-live="polite">
            <div class="po-empty__art" aria-hidden="true">
                <svg width="120" height="100" viewBox="0 0 120 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="18" y="22" width="84" height="56" rx="12" fill="#F1F5F9" stroke="#E2E8F0" stroke-width="2"/>
                    <path d="M38 42h44M38 52h32" stroke="#CBD5E1" stroke-width="3" stroke-linecap="round"/>
                    <circle cx="78" cy="38" r="8" fill="#DBEAFE"/>
                    <path d="M74 38l2.5 2.5L82 34" stroke="#2563EB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <p class="po-empty__text"></p>
        </div>
        <div id="poTableScroll" class="po-table-scroll">
            <div id="poSkeleton" class="po-skeleton" hidden aria-hidden="true">
                <div class="po-skeleton__card"></div>
                <div class="po-skeleton__card"></div>
                <div class="po-skeleton__card"></div>
                <div class="po-skeleton__card"></div>
            </div>
            <table class="po-table">
                <thead>
                    <tr>
                        <th class="th-check" scope="col"><span class="visually-hidden">Select</span></th>
                        <th class="th-status" scope="col">Status</th>
                        <th scope="col">PO #</th>
                        <th scope="col">Vendor</th>
                        <th class="po-th-agent" scope="col">Created by</th>
                        <th class="num po-th-date" scope="col">Date</th>
                        <th class="num" scope="col">Amount</th>
                        <th scope="col" class="actions">Actions</th>
                    </tr>
                </thead>
                <tbody id="poTableBody">
                @foreach (var row in Model.Orders)
                {
                    var statusClass = row.Status == "Approved" ? "po-status-stack--approved" : row.Status == "Rejected" ? "po-status-stack--rejected" : "po-status-stack--pending";
                    <tr class="po-row" data-po="@row.PoNumber"
                        data-doc-key="@row.DocKey"
                        data-vendor="@row.Vendor"
                        data-amount="@row.Amount.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                        data-transferable="@(row.Transferable == true ? "true" : row.Transferable == false ? "false" : "")"
                        data-status="@row.Status"
                        data-description="@row.Description"
                        data-order-date="@row.OrderDate.ToString("yyyy-MM-dd")">
                        <td class="td-check" data-label="">
                            @if (row.Status == "Pending")
                            {
                                <input type="checkbox" class="row-select" aria-label="Select @row.PoNumber" />
                            }
                        </td>
                        <td class="po-status-td" data-label="">
                            <div class="po-status-stack @statusClass">
                                <span class="po-status-icon" aria-hidden="true"></span>
                                <span class="po-status-text">@(row.Status == "Rejected" ? "Cancelled" : row.Status)</span>
                            </div>
                        </td>
                        <td class="po-num" data-label="PO #">
                            <span class="po-num-text">@row.PoNumber</span>
                        </td>
                        <td class="po-vendor" data-label="Vendor">@row.Vendor</td>
                        <td class="po-agent" data-label="Created by">—</td>
                        <td class="num po-date" data-label="Date">@row.OrderDate.ToString("dd MMM yyyy", System.Globalization.CultureInfo.InvariantCulture)</td>
                        <td class="num po-amount" data-label="Amount">@row.Amount.ToString("N2")</td>
                        <td class="actions" data-label="">
                            <div class="actions-row-block">
                                <div class="actions-inner">
                                    <button type="button" class="po-btn po-btn--review btn-review" data-action="review">Review</button>
                                    <button type="button" class="po-btn po-btn--reject btn-reject" data-action="reject">Reject</button>
                                    <button type="button" class="po-btn po-btn--approve btn-approve" data-action="approve">Approve</button>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
        <p class="po-footer-note">Managed by ProAcc System Consulting.</p>
    </div>
</main>

<div id="reviewModal" class="modal modal--sheet" aria-hidden="true">
    <div class="modal__backdrop" data-close></div>
    <div class="modal__sheet" role="dialog" aria-modal="true" aria-label="Purchase order details">
        <div class="modal__sheet-handle" aria-hidden="true"></div>
        <div class="modal__sheet-top">
            <button type="button" class="modal__icon-btn" data-close aria-label="Close">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
            </button>
            <div class="modal__sheet-top-fill"></div>
            <button type="button" class="modal__icon-btn modal__nav-btn" id="modalPrevBtn" aria-label="Previous purchase order">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
            </button>
            <button type="button" class="modal__icon-btn modal__nav-btn" id="modalNextBtn" aria-label="Next purchase order">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
            </button>
        </div>
        <div class="modal__sheet-scroll">
            <div id="reviewBody" class="modal__body"></div>
        </div>
        <div class="modal__sheet-actions">
            <button type="button" class="po-btn po-btn--reject-outline" id="modalRejectBtn">Reject</button>
            <button type="button" class="po-btn po-btn--approve-solid" id="modalApproveBtn">Approve</button>
        </div>
    </div>
</div>

<div id="confirmModal" class="modal modal--sheet modal--confirm" aria-hidden="true">
    <div class="modal__backdrop" data-confirm-close></div>
    <div class="modal__sheet modal__sheet--narrow" role="dialog" aria-modal="true" aria-labelledby="confirmTitle">
        <div class="modal__sheet-handle" aria-hidden="true"></div>
        <div class="modal__sheet-scroll modal__sheet-scroll--padded">
            <h2 id="confirmTitle" class="modal__confirm-title">Confirm</h2>
            <div id="confirmBody" class="modal__body modal__body--confirm"></div>
        </div>
        <div class="modal__sheet-actions modal__sheet-actions--confirm">
            <button type="button" class="po-btn po-btn--neutral-outline" data-confirm-close>Cancel</button>
            <button type="button" class="po-btn po-btn--approve-solid" id="confirmOkBtn">Confirm</button>
        </div>
    </div>
</div>

<div id="poNotifyToast" class="po-notify-toast" hidden role="dialog" aria-modal="false" aria-labelledby="poNotifyToastTitle">
    <button type="button" id="poNotifyToastClose" class="po-notify-toast__x" aria-label="Dismiss">&times;</button>
    <p id="poNotifyToastTitle" class="po-notify-toast__title">New pending orders?</p>
    <p class="po-notify-toast__text">Short desktop alert while this tab stays open (~2 min checks).</p>
    <p class="po-notify-toast__fine">Incognito/private: allow each session. “Blocked” is the browser, not this app. On <strong>http://</strong> LAN IPs (192.168…), many browsers never allow notifications — use HTTPS or localhost if alerts are required.</p>
    <div class="po-notify-toast__actions">
        <button type="button" id="poNotifyEnableBtn" class="po-notify-toast__btn po-notify-toast__btn--primary">Allow</button>
        <button type="button" id="poNotifyDismissBtn" class="po-notify-toast__btn">Not now</button>
    </div>
</div>

<div id="toast" class="toast" role="status" aria-live="polite"></div>
<div id="undoToast" class="undo-toast" hidden role="status" aria-live="polite">
    <span id="undoToastMsg"></span>
    <button type="button" id="undoBtn" class="po-btn po-btn--undo">Undo</button>
</div>

<script src="~/js/po-list.js" asp-append-version="true"></script>
<script src="~/js/po-notify.js" asp-append-version="true"></script>
<script src="~/js/push-register.js" asp-append-version="true"></script>
