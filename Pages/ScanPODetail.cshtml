@page "/ScanPODetail"
@model ApprovalPO.Pages.ScanPODetailModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@inject ApprovalPO.Services.Scan.IScanPoSubmitStore ScanSubmits
@{
    var csrf = Antiforgery.GetAndStoreTokens(HttpContext).RequestToken;
    ViewData["Title"] = Model.Order?.PoNumber ?? "PO detail";
    ViewData["AppName"] = "Approval PO";
    var userName = User.Identity?.Name ?? User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "User";
}

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="~/css/scan.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/ocr/ocr-scan.css" asp-append-version="true" />

<header class="scan-header">
    <div class="scan-header-inner">
        <div class="scan-header-titles">
            <a asp-page="/ScanPO" class="scan-back-link" title="Back to list">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="15 18 9 12 15 6"/>
                </svg>
            </a>
            <h1 class="scan-header-title">@(Model.Order?.PoNumber ?? "Purchase order")</h1>
        </div>
        <div class="scan-header-actions">
            <div class="scan-menu-wrap">
                <button class="scan-menu-btn" id="scanMenuBtn" type="button" aria-expanded="false" aria-controls="scanMenuPanel" aria-label="Open menu">
                    <span></span><span></span><span></span>
                </button>
                <div id="scanMenuPanel" class="scan-menu-panel" hidden>
                    <div class="scan-menu-user">@userName</div>
                    <a asp-page="/ScanPO" class="scan-menu-link">&#8592; Back to PO list</a>
                    <a asp-page="/Dashboard" class="scan-menu-link">Back to home</a>
                    <form method="post" asp-page="/Logout" style="margin:0;padding:0">
                        <button type="submit" class="scan-menu-link scan-menu-link--danger">Sign out</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</header>

<main class="scan-main scan-main--detail">
    <div class="scan-main-inner">
        @if (Model.Order is null)
        {
            <div class="scan-empty">
                <p>Purchase order not found or not approved.</p>
                <a asp-page="/ScanPO" class="scan-detail-back-btn">Back to list</a>
            </div>
        }
        else
        {
            var o = Model.Order;
            var scanSubmitted = Model.DocKey > 0
                && ScanSubmits.GetSubmittedDocKeysAsync().ConfigureAwait(false).GetAwaiter().GetResult().Contains(Model.DocKey);
            var today = DateTime.Today.ToString("dd MMM yyyy", System.Globalization.CultureInfo.InvariantCulture);
            <div class="scan-detail-meta">
                <div class="scan-detail-field">
                    <label>PO #</label>
                    <span>@o.PoNumber</span>
                </div>
                <div class="scan-detail-field">
                    <label>PO date</label>
                    <span>@o.OrderDate.ToString("dd MMM yyyy", System.Globalization.CultureInfo.InvariantCulture)</span>
                </div>
                <div class="scan-detail-field">
                    <label>Today's date</label>
                    <span>@today</span>
                </div>
                <div class="scan-detail-field scan-detail-field--desc">
                    <label>Description</label>
                    <span>@(string.IsNullOrWhiteSpace(o.Description) ? "—" : o.Description)</span>
                </div>
                <div class="scan-detail-field scan-detail-field--scan-only">
                    @if (scanSubmitted)
                    {
                        <button type="button" class="scan-detail-scan-btn" id="scanDetailScanBtn" disabled>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <rect x="3" y="3" width="5" height="5" rx="1"/><rect x="16" y="3" width="5" height="5" rx="1"/><rect x="3" y="16" width="5" height="5" rx="1"/>
                                <path d="M21 16h-3a2 2 0 0 0-2 2v3"/><line x1="21" y1="21" x2="21" y2="21.01"/>
                            </svg>
                            <span>Scan</span>
                        </button>
                    }
                    else
                    {
                        <button type="button" class="scan-detail-scan-btn" id="scanDetailScanBtn">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <rect x="3" y="3" width="5" height="5" rx="1"/><rect x="16" y="3" width="5" height="5" rx="1"/><rect x="3" y="16" width="5" height="5" rx="1"/>
                                <path d="M21 16h-3a2 2 0 0 0-2 2v3"/><line x1="21" y1="21" x2="21" y2="21.01"/>
                            </svg>
                            <span>Scan</span>
                        </button>
                    }
                </div>
                <div class="scan-detail-field scan-detail-field--manual">
                    <label>Item code</label>
                    <div class="scan-manual-row">
                        @if (scanSubmitted)
                        {
                            <input type="text" id="scanManualCode" class="scan-manual-input" placeholder="Type item code" autocomplete="off" enterkeyhint="go" disabled />
                            <button type="button" class="scan-manual-btn" id="scanManualBtn" disabled>Go</button>
                        }
                        else
                        {
                            <input type="text" id="scanManualCode" class="scan-manual-input" placeholder="Type item code" autocomplete="off" enterkeyhint="go" />
                            <button type="button" class="scan-manual-btn" id="scanManualBtn">Go</button>
                        }
                    </div>
                </div>
                <div class="scan-detail-field scan-detail-field--ocr">
                    <label>OCR</label>
                    <button type="button" class="scan-detail-scan-btn" id="ocrOpenBtn" title="Capture a page and read its text">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M14 3v4a1 1 0 0 0 1 1h4"/>
                            <path d="M17 21H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7l5 5v11a2 2 0 0 1-2 2Z"/>
                            <line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="13" y2="17"/>
                        </svg>
                        <span>OCR scan</span>
                    </button>
                </div>
            </div>

            <div id="scanDetailConfig" hidden
                 data-doc-key="@Model.DocKey"
                 data-po-number="@(o.PoNumber)"
                 data-is-submitted="@(scanSubmitted ? "true" : "false")"
                 data-require-all-lines="true"
                 data-resolve-scan-url="@Url.Page("/ScanPODetail", null, new { handler = "ResolveScan" })"
                 data-scan-state-url="@Url.Page("/ScanPODetail", null, new { handler = "ScanState" })"
                 data-save-draft-url="@Url.Page("/ScanPODetail", null, new { handler = "SaveDraft" })"
                 data-csrf-token="@csrf"
                 data-submit-form-id="scanDetailSubmitForm"
                 data-scan-counts-input-id="scanCountsJson"></div>

            <div id="scanToastRoot" class="scan-toast-root" aria-live="polite"></div>

            <div class="scan-lines-head">
                <p class="scan-lines-title">Line items (@Model.Lines.Count)</p>
                <p id="scanSessionSummary" class="scan-session-summary">
                    <span id="scanLinesProgress">0 of @Model.Lines.Count lines scanned</span>
                    · Total scans: <strong id="scanSessionTotal">0</strong>
                    <span class="scan-session-hint">Draft saves to server; submit marks PO complete. Tap ✓ on a line to remove one scan.</span>
                </p>
                @if (!scanSubmitted)
                {
                    <button type="button" id="scanUndoLastBtn" class="scan-undo-btn" hidden>Undo last scan</button>
                }
            </div>

            <details class="scan-audit-panel" id="scanAuditPanel" hidden>
                <summary>Activity log</summary>
                <ul class="scan-audit-list" id="scanAuditList"></ul>
            </details>
            @if (Model.Lines.Count == 0)
            {
                <p class="scan-detail-empty-lines">No line items found.</p>
            }
            else
            {
                <div class="scan-table-wrap">
                    <table class="scan-lines-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Item code</th>
                                <th>Description</th>
                                <th class="num">Qty</th>
                                <th class="scan-th-status">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var n = 0; }
                            @foreach (var line in Model.Lines)
                            {
                                n++;
                                <tr data-item-code="@line.ItemCode">
                                    <td class="scan-line-num">@n</td>
                                    <td class="scan-line-code">@line.ItemCode</td>
                                    <td>@line.Description</td>
                                    <td class="num">@((line.Sqty != 0 ? line.Sqty : line.Qty).ToString("N2"))</td>
                                    <td class="scan-line-status"><span class="scan-line-tick" aria-label="Not scanned"></span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <div class="scan-detail-actions">
                <a asp-page="/ScanPO" class="scan-detail-back-btn">&#8592; Back to list</a>
                @if (!scanSubmitted)
                {
                    <form method="post" asp-page="/ScanPODetail" asp-page-handler="Submit" class="scan-detail-submit-form" id="scanDetailSubmitForm">
                        <input type="hidden" name="docKey" value="@Model.DocKey" />
                        <input type="hidden" name="scanCountsJson" id="scanCountsJson" value="" />
                        <button type="submit" class="scan-detail-submit-btn" id="scanDetailSubmitBtn">Submit</button>
                    </form>
                }
                else
                {
                    <form method="post" asp-page="/ScanPODetail" asp-page-handler="Reopen" class="scan-detail-reopen-form" id="scanDetailReopenForm">
                        <input type="hidden" name="docKey" value="@Model.DocKey" />
                        <button type="submit" class="scan-detail-reopen-btn">Reopen for scanning</button>
                    </form>
                }
            </div>
        }
    </div>
</main>

@if (Model.Order is not null)
{
    var ocrExpectedLinesJson = System.Text.Json.JsonSerializer.Serialize(
        Model.Lines.Select(l => new
        {
            code = l.ItemCode ?? "",
            description = l.Description ?? "",
            qty = l.Sqty != 0 ? l.Sqty : l.Qty
        }),
        new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase });
    <div id="ocrModal" class="ocr-modal" hidden aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="ocrModalTitle"
         data-capture-url="@Url.Page("/ScanPODetail", null, new { handler = "OcrCapture" })"
         data-analyze-url="@Url.Page("/ScanPODetail", null, new { handler = "OcrAnalyze" })"
         data-confirm-url="@Url.Page("/ScanPODetail", null, new { handler = "ConfirmTransfer" })"
         data-scan-po-url="@Url.Page("/ScanPO", null, new { tab = "submitted" })"
         data-doc-key="@Model.DocKey"
         data-po-number="@(Model.Order.PoNumber)"
         data-csrf-token="@csrf">
        <div class="ocr-modal__backdrop" data-ocr-close></div>
        <div class="ocr-modal__panel" role="document">
            <div class="ocr-modal__head">
                <h2 id="ocrModalTitle" class="ocr-modal__title">OCR scan</h2>
                <button type="button" class="ocr-modal__close" data-ocr-close aria-label="Close">&times;</button>
            </div>
            <div class="ocr-modal__body">
                <p class="ocr-modal__hint">Capture or choose a photo, use <strong>Rotate 90°</strong> until the page is straight, then tap <strong>Analyze document</strong> to check it against PO <strong>@(Model.Order.PoNumber)</strong>.</p>
                <script type="application/json" id="ocrExpectedLinesJson">@Html.Raw(ocrExpectedLinesJson)</script>
                <div class="ocr-modal__capture">
                    <button type="button" id="ocrCaptureBtn" class="ocr-btn ocr-btn--primary">Capture / choose image</button>
                    <input type="file" id="ocrFileInput" accept="image/*" capture="environment" hidden />
                </div>
                <div id="ocrPreviewWrap" class="ocr-preview" hidden>
                    <div class="ocr-preview__toolbar">
                        <button type="button" id="ocrRotateBtn" class="ocr-btn ocr-btn--outline ocr-preview__rotate" title="Rotate clockwise 90°">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M21 12a9 9 0 1 1-3-6.7"/><polyline points="21 3 21 9 15 9"/>
                            </svg>
                            <span>Rotate 90°</span>
                        </button>
                    </div>
                    <img id="ocrPreviewImg" class="ocr-preview__img" alt="Captured page" />
                </div>
                <div id="ocrStatus" class="ocr-status" hidden></div>
                <div id="ocrCompareWrap" class="ocr-compare" hidden aria-live="polite">
                    <div class="ocr-compare__summary" id="ocrCompareSummary"></div>
                    <div class="ocr-compare__scroll">
                        <table class="ocr-compare__table">
                            <thead>
                                <tr>
                                    <th></th>
                                    <th colspan="3">PO (system)</th>
                                    <th colspan="3">Scanned (document)</th>
                                </tr>
                                <tr>
                                    <th>Status</th>
                                    <th>Code</th>
                                    <th>Description</th>
                                    <th class="num">Qty</th>
                                    <th>Code</th>
                                    <th>Description</th>
                                    <th class="num">Qty</th>
                                </tr>
                            </thead>
                            <tbody id="ocrCompareBody"></tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="ocr-modal__foot">
                <button type="button" class="ocr-btn ocr-btn--ghost" data-ocr-close>Close</button>
                <button type="button" id="ocrAiBtn" class="ocr-btn ocr-btn--primary" hidden>Analyze document</button>
                <button type="button" id="ocrConfirmBtn" class="ocr-btn ocr-btn--success" hidden>Confirm &amp; transfer to Goods Received</button>
            </div>
        </div>
    </div>
}

<div id="qrOverlay" class="qr-overlay">
    <div class="qr-box">
        <video id="qrVideo" class="qr-video" autoplay muted playsinline></video>
        <canvas id="qrCanvas" class="qr-canvas"></canvas>
        <div class="qr-guide"></div>
        <div class="qr-guide-b"></div>
        <div class="qr-scan-line"></div>
    </div>
    <div id="qrCameraHelp" class="qr-camera-help" hidden>
        <p class="qr-camera-help-title">Camera blocked</p>
        <p class="qr-camera-help-lead"><strong>This app cannot reset camera permission.</strong> Only your browser or phone settings can. Use <strong>Take photo</strong> below, or change permission manually.</p>
        <div class="qr-camera-help-actions">
            <button type="button" id="qrUsePhotoBtn" class="qr-retry-camera-btn">Take photo of QR</button>
            <button type="button" id="qrRetryCameraBtn" class="qr-use-photo-btn" hidden>Try live camera again</button>
        </div>
        <p id="qrCameraPermState" class="qr-camera-perm-state" hidden></p>
        <p class="qr-camera-help-sub">Reset in browser (pick yours):</p>
        <details class="qr-camera-help-details" open>
            <summary>Phone — Chrome / Edge</summary>
            <ol class="qr-camera-help-steps">
                <li>Tap <strong>⋮</strong> (menu) → <strong>Settings</strong> → <strong>Site settings</strong> → <strong>Camera</strong> → remove block for this site, or set <strong>Ask</strong>.</li>
                <li>Or: <strong>⋮</strong> → <strong>Info</strong> / lock icon on the page → <strong>Permissions</strong> → <strong>Camera</strong> → <strong>Allow</strong>.</li>
                <li>Close this tab, open the scan page again, tap <strong>Scan</strong>.</li>
            </ol>
        </details>
        <details class="qr-camera-help-details">
            <summary>iPhone — Safari</summary>
            <ol class="qr-camera-help-steps">
                <li><strong>Settings</strong> → <strong>Safari</strong> → <strong>Camera</strong> → <strong>Ask</strong> or <strong>Allow</strong>.</li>
                <li>Or on the page: <strong>aA</strong> in the address bar → <strong>Website Settings</strong> → <strong>Camera</strong> → <strong>Allow</strong>.</li>
                <li>Reload the page, then tap <strong>Scan</strong>.</li>
            </ol>
        </details>
        <details class="qr-camera-help-details">
            <summary>PC — Chrome / Edge</summary>
            <ol class="qr-camera-help-steps">
                <li>Click the <strong>lock</strong> left of the address → <strong>Site settings</strong>.</li>
                <li>Find <strong>Camera</strong> → <strong>Allow</strong> (or <strong>Reset permission</strong>, then reload).</li>
                <li>Reload, then tap <strong>Scan</strong>. Use <strong>https://…</strong> (HTTPS port) for live camera.</li>
            </ol>
        </details>
    </div>
    <div id="qrPhotoPanel" class="qr-photo-panel" hidden>
        <p class="qr-photo-hint" id="qrPhotoHint">Using HTTP — live camera needs HTTPS. Take a photo of the QR, or open <strong id="qrHttpsLink"></strong></p>
        <button type="button" id="qrPhotoBtn" class="qr-photo-btn">Take photo</button>
        <input type="file" id="qrPhotoInput" accept="image/*" capture="environment" hidden />
    </div>
    <p id="qrStatus" class="qr-status">Point camera at a QR code…</p>
    <button id="qrCloseBtn" class="qr-close-btn" type="button">Cancel</button>
</div>

<script src="https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.js"></script>
<script src="~/js/scan-qr-scanner.js" asp-append-version="true"></script>
<script src="~/js/scan-resolve.js" asp-append-version="true"></script>
<script src="~/js/scan-po-detail.js" asp-append-version="true"></script>
<script src="~/js/ocr/ocr-scan.js" asp-append-version="true"></script>
<script>
    (function () {
        var link = document.getElementById('qrHttpsLink');
        if (link && !window.isSecureContext) {
            var host = location.hostname || 'localhost';
            var httpsMeta = document.querySelector('meta[name="approval-https-port"]');
            var httpsPort = (httpsMeta && httpsMeta.content) ? httpsMeta.content : '2096';
            var url = 'https://' + host + ':' + httpsPort + location.pathname + location.search;
            link.textContent = url;
            link.style.wordBreak = 'break-all';
        }
        var btn = document.getElementById('scanMenuBtn');
        var panel = document.getElementById('scanMenuPanel');
        if (!btn || !panel) return;
        btn.addEventListener('click', function (e) {
            e.stopPropagation();
            var open = !panel.hidden;
            panel.hidden = open;
            btn.setAttribute('aria-expanded', String(!open));
        });
        document.addEventListener('click', function () { panel.hidden = true; btn.setAttribute('aria-expanded', 'false'); });
    })();
</script>
