@page
@model ApprovalPO.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
}

<link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />

<div class="login-container">
    <input type="hidden" id="returnUrlField" name="ReturnUrl" value="@(Model.ReturnUrl ?? "")" />
    

    <h2>Sign in with OTP</h2>
    
    <div id="idGroup">
        <div class="hp-field" aria-hidden="true">
            <label for="companyWebsite">Company website</label>
            <input type="text" id="companyWebsite" name="companyWebsite" tabindex="-1" autocomplete="off" data-lpignore="true" inputmode="none" />
        </div>
       
        <input type="email" id="loginId" name="loginId" autocomplete="username" inputmode="email" placeholder="you@company.com" />

        <button id="sendBtn" type="button">Send OTP</button>
    </div>

    <div id="otpGroup" class="otp-wrap" style="display:none;">
        <input type="hidden" id="loginIdHidden" />

        <label class="field-label" for="otp0">6-digit OTP</label>
        <div class="otp-boxes" id="otpBoxes" role="group" aria-label="One time passcode digits">
            <input type="text" inputmode="numeric" pattern="[0-9]*" maxlength="1" class="otp" id="otp0" autocomplete="one-time-code" data-lpignore="true" aria-label="Digit 1" />
            <input type="text" inputmode="numeric" pattern="[0-9]*" maxlength="1" class="otp" id="otp1" autocomplete="one-time-code" data-lpignore="true" aria-label="Digit 2" />
            <input type="text" inputmode="numeric" pattern="[0-9]*" maxlength="1" class="otp" id="otp2" autocomplete="one-time-code" data-lpignore="true" aria-label="Digit 3" />
            <input type="text" inputmode="numeric" pattern="[0-9]*" maxlength="1" class="otp" id="otp3" autocomplete="one-time-code" data-lpignore="true" aria-label="Digit 4" />
            <input type="text" inputmode="numeric" pattern="[0-9]*" maxlength="1" class="otp" id="otp4" autocomplete="one-time-code" data-lpignore="true" aria-label="Digit 5" />
            <input type="text" inputmode="numeric" pattern="[0-9]*" maxlength="1" class="otp" id="otp5" autocomplete="one-time-code" data-lpignore="true" aria-label="Digit 6" />
        </div>

        <button id="verifyBtn" type="button">Verify OTP</button>
    </div>

    <div id="message" class="msg" role="status"></div>

    <div class="install-cta">
        <button type="button" id="installTrigger" class="install-link" aria-haspopup="dialog" aria-expanded="false">
            <span class="install-icon" aria-hidden="true">?</span>
            Install app
        </button>
    </div>

    <div class="login-footer-credit">
        <p>Powered by ProAcc System Intelligent Tool</p>
        <p>V 1.1</p>
    </div>
</div>

<div id="installModal" class="install-modal" aria-hidden="true" hidden>
    <div class="install-modal__backdrop" data-install-close></div>
    <div class="install-modal__card" role="dialog" aria-modal="true" aria-labelledby="installModalTitle">
        <div class="install-modal__header">
            <div id="installModalTitle">Install app</div>
            <button type="button" class="install-modal__close" data-install-close aria-label="Close install instructions">×</button>
        </div>
        <div class="install-modal__body">
            <div class="install-section">
                <div class="install-badge">Android · Chrome</div>
                <ol>
                    <li>Tap the ⋮ More menu.</li>
                    <li>
                        Select
                        <button type="button" id="installFromModalBtn" class="install-inline-btn">
                            Add to home screen
                        </button>
                    </li>
                </ol>
                <p id="androidInstallHint" class="install-hint" hidden>
                    Native install prompt is not available yet. Use Chrome menu (⋮) and choose Add to home screen.
                </p>
            </div>
            <div class="install-section">
                <div class="install-badge">iOS · Safari</div>
                <ol>
                    <li>Tap <strong>Share</strong>.</li>
                    <li>
                        Choose
                        <button type="button" id="installFromIosBtn" class="install-inline-btn">
                            Add to Home Screen
                        </button>
                    </li>
                </ol>
                <p id="iosInstallHint" class="install-hint" hidden>
                    Safari cannot open the install prompt automatically. Tap Share, then Add to Home Screen to create the shortcut.
                </p>
            </div>
        </div>
    </div>
</div>

<script>
(() => {
    const msg = (t, isError) => {
        const el = document.getElementById('message');
        el.textContent = t || '';
        el.classList.toggle('msg--error', !!isError);
    };

    const sendBtn = document.getElementById('sendBtn');
    const verifyBtn = document.getElementById('verifyBtn');
    const loginIdEl = document.getElementById('loginId');
    const loginHidden = document.getElementById('loginIdHidden');
    const otpInputs = Array.from(document.querySelectorAll('.otp'));
    const idGroup = document.getElementById('idGroup');
    const otpGroup = document.getElementById('otpGroup');
    const otpBoxes = document.getElementById('otpBoxes');

    const otpString = () => otpInputs.map((input) => (input.value || '').replace(/\D/g, '').slice(0, 1)).join('');

    /** Main row 0–9 and numeric keypad (Numpad0–Numpad9); ignores NumLock off navigation keys. */
    const digitFromKeyEvent = (e) => {
      if (e.ctrlKey || e.metaKey || e.altKey) return null;
      const k = e.key;
      if (k && k.length === 1 && k >= '0' && k <= '9') return k;
      if (e.code) {
        const m = /^Numpad(\d)$/.exec(e.code);
        if (m) return m[1];
      }
      return null;
    };

    let verifyInFlight = false;

    const tryAutoVerify = () => {
        const otp = otpString();
        if (otp.length === 6 && /^\d{6}$/.test(otp)) {
            void runVerify();
        }
    };

    const runVerify = async () => {
        if (verifyInFlight) return;
        verifyInFlight = true;
        verifyBtn.disabled = true;
        verifyBtn.textContent = 'Verifying...';
        try {
            const loginId = (loginHidden.value || '').trim();
            const otp = otpString();
            if (!loginId) {
                msg('Email missing. Refresh and try again.', true);
                return;
            }
            if (otp.length !== 6 || !/^\d{6}$/.test(otp)) {
                msg('OTP must be exactly 6 digits.', true);
                return;
            }
            msg('');
            const fd = new FormData();
            fd.append('LoginId', loginId);
            fd.append('Otp', otp);
            const hp = document.getElementById('companyWebsite');
            if (hp) fd.append('companyWebsite', hp.value || '');
            const ru = document.getElementById('returnUrlField');
            if (ru && ru.value) fd.append('ReturnUrl', ru.value);
            const res = await fetch('@Url.Page("/Login", null, new { handler = "VerifyOtp" })', {
                method: 'POST',
                body: fd
            });
            const data = await res.json().catch(() => ({}));
            if (!res.ok || !data.success) {
                let t = data.message || 'Verification failed.';
                if (data.diagnostic) t += '\n\n' + data.diagnostic;
                msg(t, true);
                otpInputs.forEach((input) => { input.value = ''; });
                otpInputs[0]?.focus();
                return;
            }
            window.location.href = data.redirectUrl || '@Url.Page("/PurchaseOrders")';
        } catch {
            msg('Network error.', true);
        } finally {
            verifyInFlight = false;
            verifyBtn.disabled = false;
            verifyBtn.textContent = 'Verify OTP';
        }
    };

    const runSendOtp = async () => {
        const loginId = (loginIdEl.value || '').trim();
        if (!loginId) {
            msg('Please enter your work email.', true);
            return;
        }
        msg('');
        sendBtn.disabled = true;
        sendBtn.textContent = 'Sending...';
        try {
            const fd = new FormData();
            fd.append('LoginId', loginId);
            const hp = document.getElementById('companyWebsite');
            if (hp) fd.append('companyWebsite', hp.value || '');
            const res = await fetch('@Url.Page("/Login", null, new { handler = "SendOtp" })', {
                method: 'POST',
                body: fd
            });
            const data = await res.json().catch(() => ({}));
            if (!res.ok || !data.success) {
                let t = data.message || 'Could not send OTP.';
                if (data.diagnostic) t += '\n\n' + data.diagnostic;
                msg(t, true);
                return;
            }
            msg(data.message || '');
            loginHidden.value = loginId;
            idGroup.style.display = 'none';
            otpGroup.style.display = 'block';
            otpInputs.forEach((input) => { input.value = ''; });
            const d = (data.devOtp || '').toString().trim();
            if (/^\d{6}$/.test(d)) {
                for (let i = 0; i < 6; i++) otpInputs[i].value = d[i];
            }
            otpInputs[0]?.focus();
        } catch {
            msg('Network error.', true);
        } finally {
            sendBtn.disabled = false;
            sendBtn.textContent = 'Send OTP';
        }
    };

    sendBtn.addEventListener('click', () => void runSendOtp());

    loginIdEl.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
            e.preventDefault();
            void runSendOtp();
        }
    });

    otpBoxes.addEventListener('keydown', (e) => {
        const el = e.target;
        if (!el.classList?.contains('otp')) return;
        const idx = otpInputs.indexOf(el);
        if (idx < 0) return;

        if (e.key === 'Backspace') {
            if (!el.value && idx > 0) {
                e.preventDefault();
                otpInputs[idx - 1].focus();
                otpInputs[idx - 1].value = '';
            }
            return;
        }

        if (e.key === 'Enter' || e.code === 'NumpadEnter') {
            e.preventDefault();
            if (otpString().length === 6) void runVerify();
            return;
        }

        const digit = digitFromKeyEvent(e);
        if (digit) {
            e.preventDefault();
            el.value = digit;
            if (idx < otpInputs.length - 1) {
                otpInputs[idx + 1].focus();
            } else {
                el.blur();
            }
            tryAutoVerify();
        }
    });

    otpInputs.forEach((input, idx, arr) => {
        input.addEventListener('input', () => {
            const digits = (input.value || '').replace(/\D/g, '');
            input.value = digits.slice(-1);
            if (input.value && idx < arr.length - 1) {
                arr[idx + 1].focus();
            }
            tryAutoVerify();
        });

        input.addEventListener('paste', (e) => {
            e.preventDefault();
            const text = (e.clipboardData || window.clipboardData).getData('text') || '';
            const digits = text.replace(/\D/g, '').slice(0, 6);
            if (!digits) return;
            digits.split('').forEach((ch, i) => {
                if (arr[i]) arr[i].value = ch;
            });
            const next = Math.min(digits.length, arr.length - 1);
            arr[next].focus();
            tryAutoVerify();
        });
    });

    verifyBtn.addEventListener('click', () => void runVerify());
})();
</script>
<script>
(() => {
    let deferredPrompt = null;
    let canInstall = false;
    let isInstalled = false;

    const modal = document.getElementById('installModal');
    const trigger = document.getElementById('installTrigger');
    const installFromModalBtn = document.getElementById('installFromModalBtn');
    const installFromIosBtn = document.getElementById('installFromIosBtn');
    const androidInstallHint = document.getElementById('androidInstallHint');
    const iosInstallHint = document.getElementById('iosInstallHint');
    const body = document.body;

    if (!modal || !trigger) {
        return;
    }

    const isIosSafari = () => {
        const ua = window.navigator.userAgent;
        const isIOS = /iphone|ipad|ipod/i.test(ua);
        const isWebKit = /webkit/i.test(ua);
        const isCriOS = /crios/i.test(ua);
        const isFxiOS = /fxios/i.test(ua);
        return isIOS && isWebKit && !isCriOS && !isFxiOS;
    };

    const updateInstallVisibility = () => {
        const showInstall = !isInstalled;
        trigger.hidden = !showInstall;
    };

    const standaloneDisplay = window.matchMedia('(display-mode: standalone)').matches;
    const iosStandalone = window.navigator.standalone === true;
    isInstalled = standaloneDisplay || iosStandalone;
    updateInstallVisibility();

    const closeTargets = modal.querySelectorAll('[data-install-close]');

    const openModal = () => {
        modal.hidden = false;
        modal.classList.add('open');
        modal.setAttribute('aria-hidden', 'false');
        trigger.setAttribute('aria-expanded', 'true');
        body.classList.add('modal-open');
    };

    const closeModal = () => {
        modal.hidden = true;
        modal.classList.remove('open');
        modal.setAttribute('aria-hidden', 'true');
        trigger.setAttribute('aria-expanded', 'false');
        body.classList.remove('modal-open');
    };

    const openIosShareSheet = async () => {
        if (!isIosSafari() || typeof navigator.share !== 'function') {
            return false;
        }

        try {
            await navigator.share({
                title: document.title,
                text: 'Open the Share menu and choose Add to Home Screen.',
                url: window.location.href
            });
            return true;
        } catch (_) {
            return false;
        }
    };

    const handleInstallClick = async (showFallbackModal = true, hintTarget = 'none') => {
        if (androidInstallHint) androidInstallHint.hidden = true;
        if (iosInstallHint) iosInstallHint.hidden = true;

        if (deferredPrompt) {
            await deferredPrompt.prompt();
            try {
                const choice = await deferredPrompt.userChoice;
                if (choice.outcome === 'accepted') {
                    canInstall = false;
                }
            } catch (_) {
            }

            deferredPrompt = null;
            canInstall = false;
            updateInstallVisibility();
            return;
        }

        if (!isInstalled && showFallbackModal) {
            openModal();
        }

        if (!isInstalled && hintTarget === 'android' && androidInstallHint) {
            androidInstallHint.hidden = false;
        }

        if (!isInstalled && hintTarget === 'ios' && iosInstallHint) {
            const shareOpened = await openIosShareSheet();
            iosInstallHint.textContent = shareOpened
                ? 'Share menu opened. Tap Add to Home Screen to create the shortcut.'
                : 'Safari cannot open the install prompt automatically. Tap Share, then Add to Home Screen to create the shortcut.';
            iosInstallHint.hidden = false;
        }
    };

    const handleBeforeInstallPrompt = (event) => {
        event.preventDefault();
        deferredPrompt = event;
        canInstall = true;
        updateInstallVisibility();
    };

    const handleAppInstalled = () => {
        isInstalled = true;
        canInstall = false;
        deferredPrompt = null;
        closeModal();
        updateInstallVisibility();
    };

    window.addEventListener('beforeinstallprompt', handleBeforeInstallPrompt);
    window.addEventListener('appinstalled', handleAppInstalled);

    trigger.addEventListener('click', handleInstallClick);
    installFromModalBtn?.addEventListener('click', () => handleInstallClick(true, 'android'));
    installFromIosBtn?.addEventListener('click', () => handleInstallClick(false, 'ios'));
    closeTargets.forEach((el) => el.addEventListener('click', closeModal));

    document.addEventListener('keydown', (evt) => {
        if (evt.key === 'Escape') {
            closeModal();
        }
    });
})();
</script>
