@page "/ScanReceivedDetail"
@model ApprovalPO.Pages.ScanReceivedDetailModel
@{
    ViewData["Title"] = Model.Receipt?.GrNumber ?? "Received goods";
    ViewData["AppName"] = "Approval PO";
    var userName = User.Identity?.Name ?? User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "User";
}

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="~/css/scan.css" asp-append-version="true" />

<header class="scan-header">
    <div class="scan-header-inner">
        <div class="scan-header-titles">
            <a asp-page="/ScanPO" asp-route-tab="received" class="scan-back-link" title="Back to list">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="15 18 9 12 15 6"/>
                </svg>
            </a>
            <h1 class="scan-header-title">@(Model.Receipt?.GrNumber ?? "Received goods")</h1>
        </div>
        <div class="scan-header-actions">
            <div class="scan-menu-wrap">
                <button class="scan-menu-btn" id="scanMenuBtn" type="button" aria-expanded="false" aria-controls="scanMenuPanel" aria-label="Open menu">
                    <span></span><span></span><span></span>
                </button>
                <div id="scanMenuPanel" class="scan-menu-panel" hidden>
                    <div class="scan-menu-user">@userName</div>
                    <a asp-page="/ScanPO" asp-route-tab="received" class="scan-menu-link">&#8592; Back to list</a>
                    <a asp-page="/Dashboard" class="scan-menu-link">Back to home</a>
                    <form method="post" asp-page="/Logout" style="margin:0;padding:0">
                        <button type="submit" class="scan-menu-link scan-menu-link--danger">Sign out</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</header>

<main class="scan-main scan-main--detail">
    <div class="scan-main-inner">
        @if (Model.Receipt is null)
        {
            <div class="scan-empty">
                <p>Goods receipt not found.</p>
                <a asp-page="/ScanPO" asp-route-tab="received" class="scan-detail-back-btn">Back to list</a>
            </div>
        }
        else
        {
            var r = Model.Receipt;
            <div class="scan-detail-meta">
                <div class="scan-detail-field">
                    <label>GR #</label>
                    <span>@r.GrNumber</span>
                </div>
                <div class="scan-detail-field">
                    <label>GR date</label>
                    <span>@r.GrDate.ToString("dd MMM yyyy", System.Globalization.CultureInfo.InvariantCulture)</span>
                </div>
                <div class="scan-detail-field">
                    <label>PO #</label>
                    <span>@(string.IsNullOrWhiteSpace(r.PoNumber) ? "—" : r.PoNumber)</span>
                </div>
                <div class="scan-detail-field">
                    <label>Amount</label>
                    <span>@r.Amount.ToString("N2")</span>
                </div>
                <div class="scan-detail-field scan-detail-field--manual">
                    <label>Vendor</label>
                    <span>@(string.IsNullOrWhiteSpace(r.Vendor) ? "—" : r.Vendor)</span>
                </div>
                <div class="scan-detail-field scan-detail-field--manual">
                    <label>Description</label>
                    <span>@(string.IsNullOrWhiteSpace(r.Description) ? "—" : r.Description)</span>
                </div>
            </div>

            <div class="scan-lines-head">
                <p class="scan-lines-title">Line items (@Model.Lines.Count)</p>
            </div>
            @if (Model.Lines.Count == 0)
            {
                <p class="scan-detail-empty-lines">No line items found.</p>
            }
            else
            {
                <div class="scan-table-wrap">
                    <table class="scan-lines-table scan-lines-table--gr">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Item code</th>
                                <th>Description</th>
                                <th class="num">Qty</th>
                                <th class="num">Receive qty</th>
                                <th class="num">Return qty</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var line in Model.Lines)
                            {
                                <tr>
                                    <td class="scan-line-num">@line.LineNo</td>
                                    <td class="scan-line-code">@line.ItemCode</td>
                                    <td>@line.Description</td>
                                    <td class="num">@line.Qty.ToString("N2")</td>
                                    <td class="num scan-gr-receive">@line.ReceiveQty.ToString("N2")</td>
                                    <td class="num scan-gr-return">@line.ReturnQty.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <div class="scan-detail-actions">
                <a asp-page="/ScanPO" asp-route-tab="received" class="scan-detail-back-btn">&#8592; Back to received goods</a>
            </div>
        }
    </div>
</main>

<script>
(function () {
    const menuBtn = document.getElementById('scanMenuBtn');
    const menuPanel = document.getElementById('scanMenuPanel');
    if (!menuBtn || !menuPanel) return;
    menuBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const open = !menuPanel.hidden;
        menuPanel.hidden = open;
        menuBtn.setAttribute('aria-expanded', String(!open));
    });
    document.addEventListener('click', () => {
        menuPanel.hidden = true;
        menuBtn.setAttribute('aria-expanded', 'false');
    });
})();
</script>
