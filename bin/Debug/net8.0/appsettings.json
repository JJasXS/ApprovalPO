{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Approval": {
    "SessionHours": 2,
    "HighValueAmountThreshold": 5000,
    "OtpExpiryMinutes": 5,
    "OtpRateLimitWindowMinutes": 15,
    "OtpMaxSendsPerWindow": 3,
    "OtpMaxVerifyFailures": 5,
    "OtpLockoutMinutes": 15
  },
  "Smtp": {
    "Host": "",
    "Port": 587,
    "UseSsl": true,
    "User": "",
    "Password": "",
    "From": ""
  }
}
