# Tenant code is sent to the tenant-config API (?tenantCode=...) to load dbHost, dbPath, port, etc.
# TNT10003 currently uses dbHost=localhost in AWS — that only works if ApprovalPO runs on the SAME Windows PC
# as SQL Accounting and the .FDB exists at dbPath on that PC. Otherwise update DynamoDB so dbHost is that server's IP/hostname.
TENANT_CODE=TNT10003
#
# Firebird SYSDBA password (required for login — maps to TenantBootstrap:FirebirdPassword).
FIREBIRD_PASSWORD=masterkey
#
# Optional: only this machine can open the site (not LAN). In appsettings: App__Approval__BindLoopbackOnly=true
# PEM: place .certs/site.pem + .certs/site.key next to ApprovalPO.exe, or set APPROVALPO_TLS_PEM / APPROVALPO_TLS_KEY (paths).
# PFX: place tls/site.pfx (or set Approval:TlsPfxPath) and APPROVALPO_TLS_PFX_PASSWORD.
#
# Optional: SMTP broken — still complete OTP login (OTP returned in browser; insecure). Turn off after fixing mail:
# App__Approval__ExposeOtpWhenEmailFails=true
# Or flat env (no double-underscore): APPROVALPO_ALLOW_OTP_WITHOUT_EMAIL=true
#
# OTP mail uses the same tenant "email" block + Secrets Manager as ProAccScanner when Dynamo has smtpAppPasswordSecretRef.
# Set AWS_REGION (or appsettings AWS:Region) and give this host IAM or ~/.aws credentials that can read that secret.
#
# Optional: OpenAI vision OCR (Analyze with AI on the ScanPO detail page). Key stays server-side only.
# OPENAI_API_KEY=sk-...
# or: OpenAi__ApiKey=sk-...   (and optionally OpenAi__Model=gpt-4o-mini)
