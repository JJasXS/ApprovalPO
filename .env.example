# Tenant code is sent to the tenant-config API (?tenantCode=...) to load dbHost, dbPath, port, etc.
# TNT10003 currently uses dbHost=localhost in AWS — that only works if ApprovalPO runs on the SAME Windows PC
# as SQL Accounting and the .FDB exists at dbPath on that PC. Otherwise update DynamoDB so dbHost is that server's IP/hostname.
TENANT_CODE=TNT10003
